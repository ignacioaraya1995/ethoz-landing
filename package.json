{
	"name": "ethoz-landing",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:feedback": "PUBLIC_FEEDBACK_MODE=true vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test:unit": "vitest run",
		"test:unit:watch": "vitest",
		"test:e2e": "playwright test --grep-invert 'DB Integration'",
		"test:integration": "playwright test tests/db-integration.spec.ts",
		"test:ci": "npm run check && npm run test:unit && playwright test --grep-invert 'DB Integration'",
		"video:render": "node scripts/generate-pitch-video.mjs"
	},
	"devDependencies": {
		"@lucide/svelte": "^1.7.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/jest-dom": "^6.9.1",
		"jsdom": "^29.0.1",
		"playwright": "^1.59.1",
		"sharp": "^0.34.5",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "~5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.5",
		"@remotion/bundler": "^4.0.446",
		"@sentry/browser": "^10.47.0",
		"@supabase/supabase-js": "^2.101.1",
		"@sveltejs/adapter-static": "^3.0.8",
		"bits-ui": "^2.16.5",
		"clsx": "^2.1.1",
		"leaflet": "^1.9.4",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2"
	}
}
